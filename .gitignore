# Modelos (archivos pesados) — se sirven desde Hugging Face Hub, no se versionan.
# Se usan ambos patrones para cubrir la raíz de model/ y sus subcarpetas
# (yuca/ platano/ cacao/), ya que `model/*.pth` no alcanza subdirectorios.
backend/model/**/*.h5
backend/model/**/*.pt
backend/model/**/*.pkl
backend/model/**/*.pth
backend/model/*.h5
backend/model/*.pt
backend/model/*.pkl
backend/model/*.pth

# Entornos virtuales Python
backend/venv/
backend/.venv/
backend/env/

# Caché Python
__pycache__/
*.pyc
*.pyo

# Dependencias Node
frontend/node_modules/
frontend/dist/

# Variables de entorno
.env
.env.local

# Credenciales Kaggle
kaggle.json

# IDEs
.vscode/
.idea/

# Windows
Thumbs.db
desktop.ini
